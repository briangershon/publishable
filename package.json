{
  "name": "@briangershon/publishable",
  "version": "0.1.3",
  "description": "A tool for creating and managing content for publication.",
  "type": "module",
  "bin": {
    "publishable": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && chmod +x dist/index.js",
    "lint": "oxlint src",
    "check": "npm run lint && tsc --noEmit && prettier --check .",
    "format": "prettier --write .",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "cli",
    "publishing",
    "agents",
    "blog"
  ],
  "author": "Brian Gershon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briangershon/publishable.git"
  },
  "engines": {
    "node": ">=v22.22.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxlint": "latest",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  }
}
